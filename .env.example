# Garmin Health API (spec 06) — PARKED / FUTURE FEATURE (not currently wired up).
# Kept as a reference for if/when Garmin live sync is revived. Obtain values by
# registering a Garmin Connect Developer app. Copy to .env.local; never commit secrets.
GARMIN_CLIENT_ID=your-client-id
GARMIN_CLIENT_SECRET=your-client-secret
# Must match the redirect URI registered in the Garmin developer portal:
GARMIN_REDIRECT_URI=https://your-public-host/api/garmin/callback
# Optional: OAuth scope string, if your Garmin app requires one.
# GARMIN_SCOPE=

# Optional endpoint overrides (defaults target Garmin's production OAuth2/PKCE + API).
# GARMIN_AUTH_URL=https://connect.garmin.com/oauth2Confirm
# GARMIN_TOKEN_URL=https://diauth.garmin.com/di-oauth2-service/oauth/token
# GARMIN_API_BASE=https://apis.garmin.com

# Optional: override the SQLite file location.
# DATABASE_PATH=./data/wellness.db
